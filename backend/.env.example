# Copy this file to .env and fill in real values. Never commit .env.
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL connection string (supplied by your infra team)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appifylab?schema=public"

# JWT (use a long random secret in production, e.g. `openssl rand -base64 48`)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS: comma-separated origins, or "*" to allow all (dev only)
CORS_ORIGIN="*"

# Optional: absolute public base URL for generated image links
# PUBLIC_BASE_URL="https://api.example.com"

# Uploads
UPLOAD_DEST="uploads"
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,image/webp"
